# Database (Neon - get from neon.tech dashboard)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/clinicpay?sslmode=require

# Redis (Upstash - get from upstash.com console)
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Auth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Encryption (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-32-byte-hex-key-here
NRIC_HMAC_KEY=your-32-byte-hex-key-here

# S3/MinIO (optional for MVP, can use local filesystem)
S3_ENDPOINT=
S3_BUCKET=clinicpay
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-southeast-1
